generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SELLER
  ADMIN
}

enum SellerStatus {
  PENDING
  APPROVED
  PROFILE_SUBMITTED
  ACTIVE
  SUSPENDED
}

enum StockStatus {
  AVAILABLE
  LOCKED
  SOLD
}

enum ProductType {
  AKUN_READY
  MANUAL
}

enum OrderStatus {
  PENDING
  PAID
  WAITING_SELLER
  EXPIRED
  FAILED
  FULFILLED
}

enum LedgerType {
  SELLER_CREDIT
  OPERATOR_MARKUP
  SUBSCRIPTION_FEE
}

enum SubStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
}

enum MarkupMode {
  FIXED
  RANDOM
}

enum ReportStatus {
  OPEN
  RESPONDED
  RESOLVED
  ESCALATED
}

enum OtpChannel {
  EMAIL
  PHONE
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  emailVerified Boolean  @default(false)
  role          Role     @default(SELLER)
  seller        Seller?
  otps          Otp[]
  createdAt     DateTime @default(now())
}

model Seller {
  id                   String                @id @default(cuid())
  userId               String                @unique
  user                 User                  @relation(fields: [userId], references: [id])
  ownerName            String
  storeName            String
  phone                String
  phoneVerified        Boolean               @default(false)
  tgUserId             BigInt?               @unique
  storeCode            String?               @unique
  status               SellerStatus          @default(PENDING)
  categories           Category[]
  apps                 App[]
  appTemplates         AppTemplate[]
  ledgerEntries        LedgerEntry[]
  profile              SellerProfile?
  subscriptions        Subscription[]
  reports              Report[]
  affiliations         BuyerAffiliation[]
  telegramVerification TelegramVerification?
  createdAt            DateTime              @default(now())
}

model Otp {
  id         String     @id @default(cuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id])
  channel    OtpChannel
  codeHash   String
  attempts   Int        @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime   @default(now())

  @@index([userId, channel])
}

model TelegramVerification {
  id        String   @id @default(cuid())
  sellerId  String   @unique
  seller    Seller   @relation(fields: [sellerId], references: [id])
  token     String   @unique
  tgUserId  BigInt?
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model SellerProfile {
  id         String    @id @default(cuid())
  sellerId   String    @unique
  seller     Seller    @relation(fields: [sellerId], references: [id])
  encPayout  String
  payoutIv   String
  payoutTag  String
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())
}

model Category {
  id           String        @id @default(cuid())
  name         String
  icon         String?
  isDefault    Boolean       @default(false)
  sellerId     String?
  seller       Seller?       @relation(fields: [sellerId], references: [id])
  appTemplates AppTemplate[]
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())

  @@unique([name, sellerId])
}

model AppTemplate {
  id         String    @id @default(cuid())
  categoryId String
  category   Category  @relation(fields: [categoryId], references: [id])
  name       String
  isDefault  Boolean   @default(false)
  createdBy  String?
  creator    Seller?   @relation(fields: [createdBy], references: [id])
  apps       App[]
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@unique([name, categoryId])
}

model App {
  id         String      @id @default(cuid())
  templateId String
  template   AppTemplate @relation(fields: [templateId], references: [id])
  sellerId   String
  seller     Seller      @relation(fields: [sellerId], references: [id])
  notes      String?
  active     Boolean     @default(true)
  durations  Duration[]
  deletedAt  DateTime?
  createdAt  DateTime    @default(now())

  @@unique([templateId, sellerId])
}

model Duration {
  id             String      @id @default(cuid())
  appId          String
  app            App         @relation(fields: [appId], references: [id])
  label          String
  days           Int
  basePrice      Int
  productType    ProductType @default(AKUN_READY)
  buyerInfoLabel String?
  manualStock    Int?
  active         Boolean     @default(true)
  accounts       Account[]
  orders         Order[]
  deletedAt      DateTime?
  createdAt      DateTime    @default(now())
}

model Account {
  id          String       @id @default(cuid())
  durationId  String
  duration    Duration     @relation(fields: [durationId], references: [id])
  encEmail    String
  emailIv     String
  emailTag    String
  encPassword String
  passwordIv  String
  passwordTag String
  status         StockStatus  @default(AVAILABLE)
  hasSubAccounts Boolean      @default(true)
  subAccounts    SubAccount[]
  order          Order?
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
}

model SubAccount {
  id        String      @id @default(cuid())
  accountId String
  account   Account     @relation(fields: [accountId], references: [id])
  encName   String
  nameIv    String
  nameTag   String
  encPin    String
  pinIv     String
  pinTag    String
  status    StockStatus @default(AVAILABLE)
  order     Order?
  deletedAt DateTime?
  createdAt DateTime    @default(now())
}

model Order {
  id                 String        @id @default(cuid())
  buyerTgUserId      BigInt
  buyerName          String?
  buyerUsername       String?
  durationId         String?
  duration           Duration?     @relation(fields: [durationId], references: [id])
  accountId          String?       @unique
  account            Account?      @relation(fields: [accountId], references: [id])
  subAccountId       String?       @unique
  subAccount         SubAccount?   @relation(fields: [subAccountId], references: [id])
  buyerInfo          String?
  sellerNote         String?
  basePrice          Int
  markup             Int
  totalAmount        Int
  partnerReferenceNo String        @unique
  danaReferenceNo    String?
  status             OrderStatus   @default(PENDING)
  qrContent          String?
  expiresAt          DateTime
  createdAt          DateTime      @default(now())
  fulfilledAt        DateTime?
  accessExpiresAt    DateTime?
  reminderEnabled    Boolean       @default(false)
  ledgerEntries      LedgerEntry[]
  reports            Report[]
}

model LedgerEntry {
  id             String     @id @default(cuid())
  sellerId       String?
  seller         Seller?    @relation(fields: [sellerId], references: [id])
  orderId        String?
  order          Order?     @relation(fields: [orderId], references: [id])
  subscriptionId String?
  type           LedgerType
  amount         Int
  createdAt      DateTime   @default(now())
}

model BotConfig {
  id          String   @id @default("singleton")
  welcomeText String   @default("")
  categories  String   @default("[]")
  featuresOn  String   @default("{}")
  updatedAt   DateTime @updatedAt
}

model MarkupConfig {
  id         String     @id @default("singleton")
  mode       MarkupMode @default(FIXED)
  fixedValue Int        @default(0)
  randomMin  Int        @default(0)
  randomMax  Int        @default(0)
  updatedAt  DateTime   @updatedAt
}

model SubscriptionPlan {
  id            String         @id @default(cuid())
  name          String
  price         Int
  periodDays    Int
  active        Boolean        @default(true)
  subscriptions Subscription[]
  createdAt     DateTime       @default(now())
}

model Subscription {
  id                 String           @id @default(cuid())
  sellerId           String
  seller             Seller           @relation(fields: [sellerId], references: [id])
  planId             String
  plan               SubscriptionPlan @relation(fields: [planId], references: [id])
  status             SubStatus        @default(PENDING)
  partnerReferenceNo String           @unique
  startedAt          DateTime?
  expiresAt          DateTime?
  createdAt          DateTime         @default(now())
}

model BuyerAffiliation {
  id            String   @id @default(cuid())
  buyerTgUserId BigInt   @unique
  sellerId      String
  seller        Seller   @relation(fields: [sellerId], references: [id])
  updatedAt     DateTime @updatedAt
}

model Report {
  id            String       @id @default(cuid())
  orderId       String
  order         Order        @relation(fields: [orderId], references: [id])
  buyerTgUserId BigInt
  sellerId      String
  seller        Seller       @relation(fields: [sellerId], references: [id])
  message       String
  status        ReportStatus @default(OPEN)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}
